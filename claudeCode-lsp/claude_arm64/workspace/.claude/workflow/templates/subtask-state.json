{
  "parent_task_id": "task-{parent_id}",
  "subtasks": [
    {
      "subtask_id": "{subtask_id}",
      "name": "{子任务名称}",
      "goal": "{子任务目标}",
      "description": "{详细描述}",
      "status": "pending|running|completed|failed|skipped",
      "dependencies": ["{dep1}", "{dep2}"],
      "agents_needed": ["{agent1}", "{agent2}"],
      "estimated_duration": 0,
      "actual_duration": 0,
      "start_time": "{timestamp}",
      "end_time": "{timestamp}",
      "complexity": "simple|standard|complex",
      "priority": "low|medium|high",
      "input": {
        "required": ["{input1}", "{input2}"],
        "optional": ["{optional_input}"]
      },
      "output": {
        "artifacts": ["{artifact1}", "{artifact2}"],
        "deliverables": ["{deliverable1}"]
      },
      "result": {
        "status": "success|failure|partial",
        "summary": "{结果摘要}",
        "metrics": {}
      },
      "errors": []
    }
  ],
  "execution_order": ["{subtask1}", "{subtask2}", "{subtask3}"],
  "can_parallel": [
    ["{subtask1}", "{subtask2}"],
    ["{subtask3}", "{subtask4}"]
  ],
  "dependencies": {
    "{subtask2}": ["{subtask1}"],
    "{subtask3}": ["{subtask1}"],
    "{subtask4}": ["{subtask2}", "{subtask3}"]
  },
  "metadata": {
    "total_subtasks": 0,
    "completed_subtasks": 0,
    "failed_subtasks": 0,
    "skipped_subtasks": 0,
    "parallel_groups": 0,
    "critical_path": ["{subtask1}", "{subtask2}", "{subtask4}"]
  }
}
